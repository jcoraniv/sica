<section class="rounded-2xl bg-white ring-1 ring-primary-200 shadow-sm <%= compact ? 'p-4' : 'p-6' %>">
  <% if title.present? || subtitle.present? || actions.present? %>
    <header class="mb-4 flex items-start justify-between gap-4">
      <div>
        <% if title.present? %>
          <h3 class="text-base font-semibold tracking-tight text-neutral-900"><%= title %></h3>
        <% end %>
        <% if subtitle.present? %>
          <p class="mt-1 text-sm text-neutral-500"><%= subtitle %></p>
        <% end %>
      </div>
      <% if actions.present? %>
        <div><%= actions %></div>
      <% end %>
    </header>
  <% end %>
  <%= content %>
</section>
