<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || t("layouts.admin.title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "https://www.gstatic.com/charts/loader.js", defer: true %>
    <%= javascript_include_tag "https://cdn.jsdelivr.net/npm/chartkick@5.0.1/dist/chartkick.min.js", defer: true %>
    <meta name="web-push-public-key" content="<%= ENV['WEB_PUSH_VAPID_PUBLIC_KEY'] %>">
    <meta name="push-debug-unsupported-browser" content="<%= t('admin.profiles.show.push.errors.unsupported_browser') %>">
    <meta name="push-debug-insecure-context" content="<%= t('admin.profiles.show.push.errors.insecure_context') %>">
    <meta name="push-debug-missing-public-key" content="<%= t('admin.profiles.show.push.errors.missing_public_key') %>">
    <meta name="push-debug-permission-denied" content="<%= t('admin.profiles.show.push.errors.permission_denied') %>">
    <meta name="push-debug-subscription-failed" content="<%= t('admin.profiles.show.push.errors.subscription_failed') %>">
    <meta name="push-debug-server-failed" content="<%= t('admin.profiles.show.push.errors.server_failed') %>">
    <meta name="push-debug-disable-failed" content="<%= t('admin.profiles.show.push.errors.disable_failed') %>">
    <meta name="push-debug-enabled" content="<%= t('admin.profiles.show.push.feedback.enabled') %>">
    <meta name="push-debug-disabled" content="<%= t('admin.profiles.show.push.feedback.disabled') %>">
  </head>
  <body class="bg-primary-50 text-neutral-800">
    <div class="min-h-screen">
      <header id="topbar" class="sticky top-0 z-30 border-b border-primary-200/70 bg-white/85 backdrop-blur-xl">
        <div class="flex w-full items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <div class="flex items-center gap-3">
            <button id="sidebar-open" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-primary-800 ring-1 ring-primary-200 shadow-sm lg:hidden">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
            <div>
              <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-neutral-500"><%= t("layouts.admin.system_name") %></p>
              <h1 class="text-sm font-semibold tracking-tight text-primary-900 sm:text-base"><%= t("layouts.admin.panel_title") %></h1>
            </div>
          </div>
          <div class="relative">
            <button id="profile-menu-button" type="button" class="inline-flex items-center gap-2 rounded-xl bg-white px-3 py-2 text-sm font-medium text-primary-800 ring-1 ring-primary-200 shadow-sm hover:bg-primary-50">
              <span class="hidden sm:inline"><%= current_user.name %></span>
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6"/>
              </svg>
            </button>
            <div id="profile-menu" class="absolute right-0 z-40 mt-2 hidden min-w-44 rounded-2xl border border-primary-200 bg-white p-2 shadow-lg">
              <%= link_to t("layouts.admin.profile"), admin_profile_path, class: "block rounded-xl px-3 py-2 text-sm text-primary-800 hover:bg-primary-50" %>
              <%= button_to t("layouts.admin.logout"), destroy_user_session_path, method: :delete, class: "mt-1 w-full rounded-xl px-3 py-2 text-left text-sm text-primary-800 hover:bg-primary-50" %>
            </div>
          </div>
        </div>
      </header>

      <div id="sidebar-overlay" class="fixed inset-0 z-30 hidden bg-neutral-900/30 backdrop-blur-[1px] lg:hidden"></div>

      <main id="admin-shell" class="w-full space-y-6 px-4 py-6 sm:px-6 lg:flex lg:items-start lg:gap-8 lg:space-y-0 lg:px-8">
        <% nav_item_classes = ->(active) { "admin-nav-item #{active ? 'admin-nav-item-active' : ''}" } %>
        <aside id="sidebar" class="fixed inset-y-20 left-4 z-40 w-[min(84vw,280px)] -translate-x-[120%] rounded-3xl border border-primary-200/70 bg-primary-50/95 p-4 shadow-xl backdrop-blur-xl transition-transform duration-300 ease-out lg:relative lg:inset-auto lg:z-10 lg:w-60 lg:translate-x-0 lg:self-start">
          <div class="mb-3 flex items-center justify-between lg:hidden">
            <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-neutral-500"><%= t("layouts.admin.navigation") %></p>
            <button id="sidebar-close" type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-white text-primary-800 ring-1 ring-primary-200">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 6L6 18M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <nav class="space-y-4">
            <section>
              <p data-sidebar-section-title class="mb-2 px-2 text-[11px] font-semibold uppercase tracking-[0.12em] text-neutral-500"><%= t("layouts.admin.sections.general") %></p>
              <div class="space-y-1">
                <%= link_to admin_root_path, class: nav_item_classes.call(current_page?(admin_root_path)), data: { nav_item: true } do %>
                  <span class="admin-nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-8 9 8M5 10v10h14V10"/></svg>
                  </span>
                  <span data-sidebar-label><%= t("layouts.admin.menu.dashboard") %></span>
                <% end %>
              </div>
            </section>

            <section>
              <p data-sidebar-section-title class="mb-2 px-2 text-[11px] font-semibold uppercase tracking-[0.12em] text-neutral-500"><%= t("layouts.admin.sections.operations") %></p>
              <div class="space-y-1">
                <% if current_user.admin? || current_user.lecturador? %>
                  <%= link_to admin_readings_path, class: nav_item_classes.call(current_page?(admin_readings_path) || current_page?(new_admin_reading_path)), data: { nav_item: true } do %>
                    <span class="admin-nav-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M6 20V4m6 16V8m6 12V12"/></svg>
                    </span>
                    <span data-sidebar-label><%= t("layouts.admin.menu.readings") %></span>
                  <% end %>
                <% end %>

                <%= link_to admin_invoices_path, class: nav_item_classes.call(current_page?(admin_invoices_path)), data: { nav_item: true } do %>
                  <span class="admin-nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M7 3h10l4 4v14H3V3h4zm10 0v4h4"/></svg>
                  </span>
                  <span data-sidebar-label><%= t("layouts.admin.menu.invoices") %></span>
                <% end %>

                <%= link_to admin_reader_zones_path, class: nav_item_classes.call(controller_name == "reader_zones"), data: { nav_item: true } do %>
                  <span class="admin-nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-6 9 6v10l-9 2-9-2V9z"/></svg>
                  </span>
                  <span data-sidebar-label><%= t("layouts.admin.menu.reader_zones") %></span>
                <% end %>
              </div>
            </section>

            <% if current_user.admin? %>
              <section>
                <p data-sidebar-section-title class="mb-2 px-2 text-[11px] font-semibold uppercase tracking-[0.12em] text-neutral-500"><%= t("layouts.admin.sections.management") %></p>
                <div class="space-y-1">
                  <%= link_to admin_payments_path, class: nav_item_classes.call(current_page?(admin_payments_path)), data: { nav_item: true } do %>
                    <span class="admin-nav-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8h18v10H3zM7 12h.01M3 8l2-4h14l2 4"/></svg>
                    </span>
                    <span data-sidebar-label><%= t("layouts.admin.menu.payments") %></span>
                  <% end %>

                  <%= link_to admin_users_path, class: nav_item_classes.call(current_page?(admin_users_path)), data: { nav_item: true } do %>
                    <span class="admin-nav-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </span>
                    <span data-sidebar-label><%= t("layouts.admin.menu.users") %></span>
                  <% end %>

                  <%= link_to admin_zones_path, class: nav_item_classes.call(current_page?(admin_zones_path)), data: { nav_item: true } do %>
                    <span class="admin-nav-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18M4 18V7l8-4 8 4v11M9 21v-6h6v6"/></svg>
                    </span>
                    <span data-sidebar-label><%= t("layouts.admin.menu.zones") %></span>
                  <% end %>

                  <%= link_to admin_categories_path, class: nav_item_classes.call(current_page?(admin_categories_path)), data: { nav_item: true } do %>
                    <span class="admin-nav-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h10"/></svg>
                    </span>
                    <span data-sidebar-label><%= t("layouts.admin.menu.categories") %></span>
                  <% end %>

                  <%= link_to admin_meters_path, class: nav_item_classes.call(current_page?(admin_meters_path)), data: { nav_item: true } do %>
                    <span class="admin-nav-icon">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 19h16M6 16V5h12v11M9 8h.01M12 8h.01M15 8h.01"/></svg>
                    </span>
                    <span data-sidebar-label><%= t("layouts.admin.menu.meters") %></span>
                  <% end %>
                </div>
              </section>
            <% end %>
          </nav>
        </aside>

        <section id="main-content" class="space-y-6 lg:min-w-0 lg:flex-1">
          <% if notice.present? %>
            <p class="rounded-2xl bg-primary-100 px-4 py-3 text-sm text-primary-800 ring-1 ring-primary-200"><%= notice %></p>
          <% end %>
          <% if alert.present? %>
            <p class="rounded-2xl bg-danger-50 px-4 py-3 text-sm text-danger-700 ring-1 ring-danger-200"><%= alert %></p>
          <% end %>
          <%= yield %>
        </section>
      </main>
    </div>

    <script>
      (() => {
        const initAdminUi = () => {
        const sidebar = document.getElementById("sidebar");
        const overlay = document.getElementById("sidebar-overlay");
        const openBtn = document.getElementById("sidebar-open");
        const closeBtn = document.getElementById("sidebar-close");
        const profileButton = document.getElementById("profile-menu-button");
        const profileMenu = document.getElementById("profile-menu");
        if (sidebar && overlay && openBtn) {
          const openSidebar = () => {
            sidebar.classList.remove("-translate-x-[120%]");
            overlay.classList.remove("hidden");
          };

          const closeSidebar = () => {
            sidebar.classList.add("-translate-x-[120%]");
            overlay.classList.add("hidden");
          };

          openBtn.onclick = openSidebar;
          if (closeBtn) closeBtn.onclick = closeSidebar;
          overlay.onclick = closeSidebar;

          window.addEventListener("resize", () => {
            if (window.innerWidth >= 1024) closeSidebar();
          }, { once: true });
        }

        if (profileButton && profileMenu) {
          profileButton.onclick = (event) => {
            event.stopPropagation();
            profileMenu.classList.toggle("hidden");
          };

          document.addEventListener("click", (event) => {
            if (profileMenu.contains(event.target) || profileButton.contains(event.target)) return;
            profileMenu.classList.add("hidden");
          }, { once: true });
        }

        const debugText = (name) => document.querySelector(`meta[name="${name}"]`)?.content || name;

        const registerPushSubscription = async () => {
          const publicKey = document.querySelector('meta[name="web-push-public-key"]')?.content;
          if (!("Notification" in window) || !("serviceWorker" in navigator) || !("PushManager" in window)) {
            return { ok: false, reason: debugText("push-debug-unsupported-browser") };
          }
          if (!window.isSecureContext) {
            return { ok: false, reason: debugText("push-debug-insecure-context") };
          }
          if (!publicKey) {
            return { ok: false, reason: debugText("push-debug-missing-public-key") };
          }

          const urlBase64ToUint8Array = (base64String) => {
            const padding = "=".repeat((4 - (base64String.length % 4)) % 4);
            const base64 = (base64String + padding).replace(/-/g, "+").replace(/_/g, "/");
            const rawData = window.atob(base64);
            const outputArray = new Uint8Array(rawData.length);
            for (let i = 0; i < rawData.length; ++i) outputArray[i] = rawData.charCodeAt(i);
            return outputArray;
          };

          try {
            const registration = await navigator.serviceWorker.register("/service-worker.js");
            let permission = window.Notification?.permission;
            if (permission === "default") permission = await window.Notification.requestPermission();
            if (permission !== "granted") {
              return { ok: false, reason: debugText("push-debug-permission-denied") };
            }

            let subscription = await registration.pushManager.getSubscription();
            if (!subscription) {
              subscription = await registration.pushManager.subscribe({
                userVisibleOnly: true,
                applicationServerKey: urlBase64ToUint8Array(publicKey)
              });
            }
            if (!subscription) {
              return { ok: false, reason: debugText("push-debug-subscription-failed") };
            }

            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
            const response = await fetch("<%= admin_push_subscription_path %>", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                "X-CSRF-Token": csrfToken,
                "Accept": "application/json"
              },
              credentials: "same-origin",
              body: JSON.stringify({ subscription: subscription.toJSON() })
            });
            if (!response.ok) {
              return { ok: false, reason: `${debugText("push-debug-server-failed")} (${response.status})` };
            }
            return { ok: true, reason: debugText("push-debug-enabled") };
          } catch (error) {
            console.debug("Web push subscription error", error);
            return { ok: false, reason: `${debugText("push-debug-subscription-failed")}: ${error.message}` };
          }
        };

        const removePushSubscription = async () => {
          let browserUnsubError = null;
          try {
            if ("serviceWorker" in navigator && "PushManager" in window) {
              const registration = await navigator.serviceWorker.register("/service-worker.js");
              const subscription = await registration.pushManager.getSubscription();
              if (subscription) {
                const unsubscribed = await subscription.unsubscribe();
                if (!unsubscribed) browserUnsubError = "unsubscribe returned false";
              }
            }
          } catch (error) {
            browserUnsubError = error.message;
            console.debug("Web push unsubscribe error", error);
          }

          try {
            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
            const response = await fetch("<%= admin_push_subscription_path %>", {
              method: "DELETE",
              headers: {
                "X-CSRF-Token": csrfToken,
                "X-Requested-With": "XMLHttpRequest",
                "Accept": "application/json"
              },
              credentials: "same-origin"
            });
            if (!response.ok) {
              return { ok: false, reason: `${debugText("push-debug-disable-failed")} (${response.status})` };
            }
            const reason = browserUnsubError ? `${debugText("push-debug-disabled")} (${browserUnsubError})` : debugText("push-debug-disabled");
            return { ok: true, reason };
          } catch (error) {
            console.debug("Push subscription delete error", error);
            return { ok: false, reason: `${debugText("push-debug-disable-failed")}: ${error.message}` };
          }
        };

        const pushStatus = document.querySelector("[data-push-status]");
        const pushToggle = document.querySelector("[data-push-toggle]");
        const pushFeedback = document.querySelector("[data-push-feedback]");
        const setPushUiState = (enabled) => {
          if (pushStatus) {
            pushStatus.textContent = enabled ? pushStatus.dataset.enabledText : pushStatus.dataset.disabledText;
            pushStatus.classList.toggle("text-success-700", enabled);
            pushStatus.classList.toggle("text-warning-700", !enabled);
          }
          if (pushToggle) pushToggle.checked = enabled;
        };
        const setPushFeedback = (message, isError = false) => {
          if (!pushFeedback) return;
          pushFeedback.textContent = message || "";
          pushFeedback.classList.toggle("text-danger-700", isError);
          pushFeedback.classList.toggle("text-neutral-500", !isError);
        };

        if (pushToggle) {
          pushToggle.onchange = async (event) => {
            pushToggle.disabled = true;
            const shouldEnable = event.target.checked;
            const previousState = !shouldEnable;
            setPushUiState(shouldEnable);
            setPushFeedback("");
            const result = shouldEnable ? await registerPushSubscription() : await removePushSubscription();
            if (!result.ok) setPushUiState(previousState);
            setPushFeedback(result.reason, !result.ok);
            pushToggle.disabled = false;
          };
        }
        };

        document.addEventListener("turbo:load", initAdminUi);
        document.addEventListener("DOMContentLoaded", initAdminUi, { once: true });
      })();
    </script>
  </body>
</html>
