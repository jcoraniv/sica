<div class="grid gap-6 xl:grid-cols-2">
  <%= render Ui::CardComponent.new(title: t("admin.payments.form.card_title")) do %>
    <% editing = @payment_form.persisted? %>
    <% form_url = editing ? admin_payment_path(@payment_form) : admin_payments_path %>
    <% form_method = editing ? :patch : :post %>
    <% submit_text = editing ? t("admin.payments.form.edit_submit") : t("admin.payments.form.create_submit") %>
    <%= form_with model: @payment_form, url: form_url, method: form_method, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :invoice_id, t("admin.payments.form.fields.pending_invoice"), class: "mb-1 block text-sm font-medium text-neutral-700" %>
        <%= f.select :invoice_id, @invoice_options.map { |i| ["##{i.id} - #{i.user.name} (Bs #{i.total_amount})", i.id] }, {}, class: "admin-input", disabled: editing %>
        <% if editing %>
          <%= hidden_field_tag :invoice_id, @payment_form.invoice_id %>
        <% end %>
      </div>
      <div>
        <%= f.label :amount_paid, editing ? t("admin.payments.form.fields.edited_amount") : t("admin.payments.form.fields.paid_amount"), class: "mb-1 block text-sm font-medium text-neutral-700" %>
        <%= f.number_field :amount_paid, step: 0.01, required: true, class: "admin-input" %>
      </div>
      <div>
        <%= f.label :paid_at, t("admin.payments.form.fields.paid_at"), class: "mb-1 block text-sm font-medium text-neutral-700" %>
        <%= f.datetime_local_field :paid_at, value: (@payment_form.paid_at || Time.current).strftime("%Y-%m-%dT%H:%M"), class: "admin-input" %>
      </div>
      <div class="flex gap-2">
        <%= render Ui::ButtonComponent.new(text: submit_text, type: :submit) %>
        <% if editing %>
          <%= render Ui::ButtonComponent.new(text: t("admin.shared.actions.cancel"), href: admin_payments_path, variant: :secondary) %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= render Ui::CardComponent.new(title: t("admin.payments.list.title")) do %>
    <%= search_form_for @q, url: admin_payments_path, method: :get, html: { class: "mb-4 grid gap-3 md:grid-cols-3" } do |f| %>
      <%= f.search_field :admin_name_cont, placeholder: t("admin.payments.list.search_admin"), class: "admin-input" %>
      <%= f.search_field :invoice_id_eq, placeholder: t("admin.payments.list.search_invoice"), class: "admin-input" %>
      <div class="flex gap-2">
        <%= render Ui::ButtonComponent.new(text: t("admin.shared.actions.search"), type: :submit) %>
        <%= render Ui::ButtonComponent.new(text: t("admin.shared.actions.clear"), href: admin_payments_path, variant: :secondary) %>
      </div>
    <% end %>

    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="text-left text-neutral-500">
          <tr>
            <th class="py-2 pr-4 font-medium"><%= t("admin.shared.fields.invoice") %></th>
            <th class="py-2 pr-4 font-medium"><%= t("admin.shared.fields.amount") %></th>
            <th class="py-2 pr-4 font-medium"><%= t("admin.payments.list.headers.admin") %></th>
            <th class="py-2 pr-4 font-medium"><%= t("admin.shared.fields.date") %></th>
            <th class="py-2 pr-4 font-medium"><%= t("admin.shared.fields.action") %></th>
          </tr>
        </thead>
        <tbody class="text-neutral-700">
          <% @payments.each do |payment| %>
            <tr>
              <td class="py-3 pr-4">#<%= payment.invoice_id %></td>
              <td class="py-3 pr-4">Bs <%= number_with_precision(payment.amount_paid, precision: 2) %></td>
              <td class="py-3 pr-4"><%= payment.admin.name %></td>
              <td class="py-3 pr-4"><%= l(payment.paid_at.to_date) %></td>
              <td class="py-3 pr-4">
                <%= link_to admin_payments_path(edit_id: payment.id), class: "inline-flex h-9 w-9 items-center justify-center rounded-xl bg-white text-neutral-700 ring-1 ring-primary-200 hover:bg-primary-50", title: t("admin.shared.actions.edit_payment"), "aria-label": t("admin.shared.actions.edit_payment") do %>
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 20h9"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.5a2.12 2.12 0 113 3L7 19l-4 1 1-4 12.5-12.5z"/>
                  </svg>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%= render "admin/shared/pagination", pagy: @pagy %>
  <% end %>
</div>
