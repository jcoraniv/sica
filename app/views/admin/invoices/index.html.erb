<%= render Ui::CardComponent.new(title: t("admin.invoices.index.title")) do %>
  <%= search_form_for @q, url: admin_invoices_path, method: :get, html: { class: "mb-4 grid gap-3 md:grid-cols-4" } do |f| %>
    <%= f.search_field :user_name_cont, placeholder: t("admin.shared.fields.user"), class: "admin-input" %>
    <%= f.select :status_eq, invoice_status_options, { include_blank: t("admin.shared.fields.status") }, class: "admin-input" %>
    <%= f.date_field :issued_at_gteq, class: "admin-input" %>
    <div class="flex gap-2">
      <%= render Ui::ButtonComponent.new(text: t("admin.shared.actions.search"), type: :submit) %>
      <%= render Ui::ButtonComponent.new(text: t("admin.shared.actions.clear"), href: admin_invoices_path, variant: :secondary) %>
    </div>
  <% end %>

  <div class="overflow-x-auto">
    <table class="min-w-full text-sm">
      <thead class="text-left text-neutral-500">
        <tr>
          <th class="py-2 pr-4 font-medium">#</th>
          <th class="py-2 pr-4 font-medium"><%= t("admin.shared.fields.user") %></th>
          <th class="py-2 pr-4 font-medium"><%= t("admin.shared.fields.amount") %></th>
          <th class="py-2 pr-4 font-medium"><%= t("admin.shared.fields.status") %></th>
          <th class="py-2 pr-4 font-medium"><%= t("admin.invoices.index.headers.issued_at") %></th>
          <th class="py-2 pr-4 font-medium"><%= t("admin.shared.fields.action") %></th>
        </tr>
      </thead>
      <tbody class="text-neutral-700">
        <% @invoices.each do |invoice| %>
          <tr>
            <td class="py-3 pr-4">#<%= invoice.id %></td>
            <td class="py-3 pr-4"><%= invoice.user.name %></td>
            <td class="py-3 pr-4">Bs <%= number_with_precision(invoice.total_amount, precision: 2) %></td>
            <td class="py-3 pr-4">
              <span class="<%= invoice_status_badge_class(invoice) %>"><%= invoice_status_label(invoice) %></span>
            </td>
            <td class="py-3 pr-4"><%= l(invoice.issued_at.to_date) %></td>
            <td class="py-3 pr-4 flex items-center gap-2">
              <% if current_user.admin? && invoice.pending? %>
                <%= link_to edit_admin_invoice_path(invoice), class: "inline-flex h-9 w-9 items-center justify-center rounded-xl bg-white text-neutral-700 ring-1 ring-primary-200 hover:bg-primary-50", title: t("admin.shared.actions.edit_invoice"), "aria-label": t("admin.shared.actions.edit_invoice") do %>
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 20h9"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.5a2.12 2.12 0 113 3L7 19l-4 1 1-4 12.5-12.5z"/>
                  </svg>
                <% end %>
              <% end %>
              <%= link_to t("admin.invoices.index.pdf"), pdf_admin_invoice_path(invoice), class: "rounded-xl bg-white px-3 py-1.5 text-xs font-medium text-neutral-700 ring-1 ring-primary-200 hover:bg-neutral-50" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= render "admin/shared/pagination", pagy: @pagy %>
<% end %>
