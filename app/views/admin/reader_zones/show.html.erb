<%= render Ui::CardComponent.new(title: t("admin.reader_zones.show.title"), subtitle: t("admin.reader_zones.show.subtitle", zone: @zone.name, count: @markers.count)) do %>
  <% if @markers.empty? %>
    <p class="text-sm text-neutral-500"><%= t("admin.reader_zones.show.no_markers") %></p>
  <% else %>
    <% api_key = ENV["GOOGLE_MAPS_API_KEY"] %>
    <% if api_key.blank? %>
      <p class="rounded-xl bg-warning-50 px-4 py-3 text-sm text-warning-700 ring-1 ring-warning-200">
        <%= t("admin.reader_zones.show.missing_google_maps_key") %>
      </p>
    <% else %>
      <div id="zone-map" class="h-[520px] w-full rounded-2xl ring-1 ring-primary-200"></div>
      <script id="zone-map-markers" type="application/json"><%= raw(@markers.to_json) %></script>
      <script>
        window.initZoneMetersMap = function() {
          const noLocation = "<%= j(t('admin.meters.fields.no_location')) %>";
          const raw = document.getElementById("zone-map-markers");
          if (!raw) return;
          const markers = JSON.parse(raw.textContent || "[]");
          if (!markers.length) return;

          const center = { lat: markers[0].latitude, lng: markers[0].longitude };
          const map = new google.maps.Map(document.getElementById("zone-map"), {
            center,
            zoom: 15,
            mapTypeControl: false,
            streetViewControl: false,
            fullscreenControl: true
          });

          markers.forEach((markerData) => {
            const marker = new google.maps.Marker({
              position: { lat: markerData.latitude, lng: markerData.longitude },
              map,
              title: markerData.serial_number
            });

            const info = new google.maps.InfoWindow({
              content: `<div style="font-size:13px"><strong>${markerData.serial_number}</strong><br/>${markerData.location || noLocation}</div>`
            });

            marker.addListener("click", () => info.open({ anchor: marker, map }));
          });
        };
      </script>
      <script async defer src="https://maps.googleapis.com/maps/api/js?key=<%= api_key %>&callback=initZoneMetersMap"></script>
    <% end %>
  <% end %>
<% end %>
