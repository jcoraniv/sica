<%= render Ui::CardComponent.new(title: t("admin.reader_zones.index.title"), subtitle: t("admin.reader_zones.index.subtitle")) do %>
  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    <% @zones.each do |zone| %>
      <article class="rounded-2xl bg-neutral-50 p-4 ring-1 ring-primary-200">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-xs uppercase tracking-wide text-neutral-500"><%= t("admin.users.fields.zone") %></p>
            <h3 class="mt-1 text-lg font-semibold text-neutral-900"><%= zone.name %></h3>
          </div>
          <%= link_to admin_reader_zone_path(zone), class: "inline-flex h-9 w-9 items-center justify-center rounded-xl bg-white text-neutral-700 ring-1 ring-primary-200 hover:bg-primary-50", title: t("admin.reader_zones.index.view_map") do %>
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 14L21 3M21 3h-7M21 3v7"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 10v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v4"/>
            </svg>
          <% end %>
        </div>
        <div class="mt-4 flex items-center gap-3">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-white text-neutral-900 ring-4 ring-primary-200">
            <span class="text-sm font-semibold"><%= zone.read_attribute(:meters_count) || zone.meters.size %></span>
          </div>
          <p class="text-sm text-neutral-600"><%= t("admin.reader_zones.index.assigned_meters") %></p>
        </div>
      </article>
    <% end %>
  </div>
<% end %>
