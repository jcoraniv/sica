<%= render Ui::CardComponent.new(title: t("admin.meters.index.title"), subtitle: t("admin.meters.index.subtitle")) do |card| %>
  <% card.with_actions do %>
    <%= render Ui::ButtonComponent.new(text: t("admin.meters.index.new"), href: new_admin_meter_path) %>
  <% end %>

  <%= search_form_for @q, url: admin_meters_path, method: :get, html: { class: "mb-4 grid gap-3 md:grid-cols-4" } do |f| %>
    <%= f.search_field :serial_number_or_location_or_user_name_cont, placeholder: t("admin.meters.index.search_placeholder"), class: "admin-input" %>
    <%= f.select :zone_id_eq, @zones.map { |z| [z.name, z.id] }, { include_blank: t("admin.users.fields.zone") }, class: "admin-input" %>
    <%= f.select :user_id_eq, @users.map { |u| [u.name, u.id] }, { include_blank: t("admin.shared.fields.user") }, class: "admin-input" %>
    <div class="flex gap-2">
      <%= render Ui::ButtonComponent.new(text: t("admin.shared.actions.search"), type: :submit) %>
      <%= render Ui::ButtonComponent.new(text: t("admin.shared.actions.clear"), href: admin_meters_path, variant: :secondary) %>
    </div>
  <% end %>

  <div class="space-y-3">
    <% @meters.each do |meter| %>
      <div class="rounded-2xl bg-neutral-50 p-4 ring-1 ring-primary-200">
        <%= form_with model: meter, url: admin_meter_path(meter), method: :patch, class: "grid gap-3 md:grid-cols-7" do |f| %>
          <div>
            <label class="mb-1 block text-xs font-medium text-neutral-600"><%= t("admin.meters.fields.serial_number") %></label>
            <%= f.text_field :serial_number, class: "admin-input" %>
          </div>
          <div>
            <label class="mb-1 block text-xs font-medium text-neutral-600"><%= t("admin.meters.fields.location") %></label>
            <%= f.text_field :location, class: "admin-input" %>
          </div>
          <div>
            <label class="mb-1 block text-xs font-medium text-neutral-600"><%= t("admin.shared.fields.user") %></label>
            <%= f.select :user_id, @users.map { |u| [u.name, u.id] }, {}, class: "admin-input" %>
          </div>
          <div>
            <label class="mb-1 block text-xs font-medium text-neutral-600"><%= t("admin.users.fields.zone") %></label>
            <%= f.select :zone_id, @zones.map { |z| [z.name, z.id] }, {}, class: "admin-input" %>
          </div>
          <div>
            <label class="mb-1 block text-xs font-medium text-neutral-600"><%= t("admin.meters.fields.latitude") %></label>
            <%= f.number_field :latitude, step: 0.000001, class: "admin-input" %>
          </div>
          <div>
            <label class="mb-1 block text-xs font-medium text-neutral-600"><%= t("admin.meters.fields.longitude") %></label>
            <%= f.number_field :longitude, step: 0.000001, class: "admin-input" %>
          </div>
          <div class="flex items-end gap-2">
            <%= render Ui::ButtonComponent.new(text: t("admin.shared.actions.save"), type: :submit) %>
            <%= link_to admin_meter_path(meter), data: { turbo_method: :delete, turbo_confirm: t("admin.meters.index.confirm_delete") }, class: "inline-flex h-9 w-9 items-center justify-center rounded-xl bg-danger-500 text-white hover:bg-danger-600", title: t("admin.shared.actions.delete_meter"), "aria-label": t("admin.shared.actions.delete_meter") do %>
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 6h18"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 6V4h8v2"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14H6L5 6"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 11v6M14 11v6"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%= render "admin/shared/pagination", pagy: @pagy %>
<% end %>
